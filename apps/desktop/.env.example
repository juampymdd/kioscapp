# Variables del local (desktop Tauri).
# En Tauri, las env vars de build-time se inyectan vía vite.config.ts.

# UUID v4 que identifica este local. Se genera una vez y se guarda.
VITE_LOCAL_ID="00000000-0000-0000-0000-000000000000"

# URL del backend central para sincronización.
VITE_BACKEND_URL="https://tu-backend.vercel.app"

# Debe coincidir con SYNC_SECRET del backend (Vercel env var).
# Si está vacío, sync funciona sin autenticación (solo para dev local).
VITE_SYNC_SECRET=""
